{
  "mcpServers": {
    "kaggle": {
      "command": "node",
      "args": [
        "path/to/@iflow-mcp/dishant27-kaggle-mcp/build/index.js"
      ],
      "env": {
        "KAGGLE_USERNAME": "${KAGGLE_USERNAME}",
        "KAGGLE_KEY": "${KAGGLE_KEY}"
      },
      "disabled": false,
      "autoApprove": []
    },
    "visionsetil-api": {
      "command": "uv",
      "args": ["run", "python", "-m", "mcp_servers.visionsetil_api"],
      "env": {
        "VISIONSETIL_BASE_URL": "http://localhost:8000/api/v1",
        "VISIONSETIL_API_KEY": "${VISIONSETIL_API_KEY}",
        "VISIONSETIL_ALLOW_MUTATIONS": "false"
      },
      "disabled": true,
      "autoApprove": []
    },
    "mycology": {
      "command": "uv",
      "args": ["run", "python", "-m", "mcp_servers.mycology"],
      "env": {
        "VISIONSETIL_BASE_URL": "http://localhost:8000/api/v1"
      },
      "disabled": true,
      "autoApprove": []
    }
  }
}
