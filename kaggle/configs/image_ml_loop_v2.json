{
  "name": "visionsetil_image_ml_loop_v2",
  "date": "2026-07-16",
  "parent": "visionsetil_image_ml_loop_v1",
  "goal": "Lift MAP@3 while holding deadly_recall=1.0 and ECE<=0.05",
  "runner": "scripts/run_image_ml_loop.py",
  "kaggle_kernel": "kaggle/visionsetil_mega_training.ipynb",
  "default_predictions": "kaggle/kernel_output_v9/models/test_predictions.npz",
  "default_label2idx": "kaggle/kernel_output_v9/models/label2idx.json",
  "local_eval": "eval/scripts/compute_full_metrics.py",
  "output_dir": "eval/reports/ml_loop_v2",
  "backbone": "convnextv2_tiny",
  "multi_view": true,
  "views": ["gills", "front", "habitat", "detail"],
  "view_dropout": 0.15,
  "attention_pooling": true,
  "loss": ["focal", "label_smoothing", "arcface_margin"],
  "focal_gamma": 2.0,
  "label_smoothing": 0.08,
  "arcface_margin": 0.35,
  "arcface_scale": 30,
  "anti_leak": "observation_id GroupKFold",
  "optimizer": "adamw",
  "lr": 3e-4,
  "weight_decay": 0.05,
  "epochs": 24,
  "batch_size": 16,
  "mixup_alpha": 0.2,
  "cutmix_prob": 0.15,
  "progressive_resize": [224, 288, 320],
  "swa": true,
  "swa_start_epoch": 16,
  "temperature_scaling": true,
  "open_set": true,
  "open_set_min_confidence": 0.42,
  "open_set_min_margin": 0.08,
  "open_set_reject_on_deadly_lookalikes": true,
  "class_balance": "effective_number",
  "deadly_oversample_factor": 2.0,
  "metrics": ["MAP@3", "top1", "top3", "macro_f1", "deadly_recall", "ECE", "toxic_recall"],
  "gates": {
    "deadly_recall_min": 1.0,
    "ece_max": 0.05,
    "false_edible_rate_max": 0.0,
    "map3_min_delta_vs_v1": 0.01
  },
  "bootstrap_iters": 1000,
  "bootstrap_ci": 0.95,
  "dataset_sources": ["FungiCLEF-style", "FungiTastic", "DF20 converters in kaggle/"],
  "commands": {
    "local_eval": "python scripts/run_image_ml_loop.py --config kaggle/configs/image_ml_loop_v2.json --output-dir eval/reports/ml_loop_v2",
    "compare_v1": "python scripts/compare_ml_loops.py --a eval/reports/ml_loop_v1 --b eval/reports/ml_loop_v2"
  },
  "notes": "v2: stronger multi-view regularization, ArcFace, SWA, temperature calibration, deadly oversample, stricter open-set defaults for production safety."
}
