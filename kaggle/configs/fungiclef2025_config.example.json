    "siglip_model_path": "/kaggle/input/visionsetil-models/siglip2"
  },
  "runtime": {
    "device": "auto",
    "batch_size": 8,
    "num_workers": 2,
    "mode": "full_pipeline"
  },
  "safety": {
    "enforce_safety_audit": true,
    "fail_on_safety_violation": true
  }
}
