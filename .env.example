# VisionSetil environment template.
# Copy to `.env` and adjust. See docs/configuration.md for full reference.

# --- Runtime environment ---
# development | staging | production
# production/prod: B-23 refuses MODEL_BLOCK_SPECIES_ID_WHEN_BELOW_GATE=false
# (process will not start). Also drives B-19 guardrail log severity.
ENVIRONMENT=development

# --- Uploads ---
MAX_IMAGE_MB=10
# ALLOWED_EXTENSIONS is a JSON-style set, e.g. ["jpg","jpeg","png","webp"]

# --- Pipeline ---
TOP_K_CANDIDATES=5

# --- Model activation ---
USE_REAL_YOLOE=false
USE_REAL_DINOV3=false
USE_REAL_SIGLIP2=false
ALLOW_MOCK_FALLBACKS=true

# --- Quality gate (fail-closed; D-B3 / B-19 / B-23) ---
# Min on-disk MAP@3 for species ID to be allowed (default 0.20).
# MODEL_MIN_ACCEPTABLE_MAP_AT_3=0.20
# When true (DEFAULT), block species ID if metrics fail the gate.
# Set false ONLY for local/dev experiments.
# B-23: Settings refuse (ValidationError) if false AND ENVIRONMENT=production|prod.
# B-19: non-prod disable still emits structured warn at boot / gate evaluation.
MODEL_BLOCK_SPECIES_ID_WHEN_BELOW_GATE=true

# --- Open-set rejection ---
OPEN_SET_MIN_CONFIDENCE=0.55
OPEN_SET_MIN_MARGIN=0.15
OPEN_SET_REJECT_ON_MISSING_CRITICAL_EVIDENCE=true
OPEN_SET_REJECT_ON_DEADLY_LOOKALIKES=true

# --- Security / runtime ---
# Comma-separated list of allowed origins. Do NOT use "*" in production.
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
LOG_FORMAT=text
REQUEST_ID_HEADER=X-Request-ID
READYZ_FAIL_ON_MOCK_MODELS=false